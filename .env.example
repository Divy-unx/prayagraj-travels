# ─────────────────────────────────────────────────────────────────────────────
# Root .env.example — safe template for docker-compose vars.
# Copy to .env and fill in your values.
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL (Docker) ────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=choose_a_strong_password
MYSQL_DATABASE=prayagraj_bus

# ── Backend Docker network overrides ─────────────────────────────────────────
# These override the values in backend/.env when running inside Docker.
# In Docker, services communicate via container names (mysql, redis), not localhost.
# Leave as-is for local Docker Compose. Override for external hosted services.
DB_HOST=mysql
REDIS_HOST=redis
REDIS_USERNAME=
REDIS_PASSWORD=

# ── Frontend build args ───────────────────────────────────────────────────────
# Baked into the Vite bundle at Docker build time.
# For production: set these as build args in your CI/CD pipeline or cloud platform.
VITE_API_BASE_URL=http://localhost:8081
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
